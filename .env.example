# Database Configuration
# Priority: 1. DATABASE_URL | 2. SUPABASE_* variables | 3. SQLite (default)
DB_MODE=local
DATABASE_LOCAL_URL=postgresql://postgres:[password]@localhost:5432/[db_name]
SUPABASE_PROJECT_ID=
SUPABASE_PASSWORD=
# For IPv4-only networks, use the pooler host from Supabase dashboard (e.g. aws-0-ap-south-1.pooler.supabase.com)
SUPABASE_HOST=aws-1-ap-south-1.pooler.supabase.com
SUPABASE_PORT=5432

# ChromaDB Configuration
# For local dev, leave API_KEY empty. For Cloud, fill in the credentials.
CHROMA_MODE=local
CHROMA_PERSIST_DIR=./db/chroma_store
CHROMA_API_KEY=your_api_key
CHROMA_TENANT=your_tenant
CHROMA_DATABASE=your_db_name

#LLM Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Embedding Configuration
EMBEDDING_MODEL=text-embedding-004 #openapi
EMBEDDING_MODEL=gemini-embedding-001 #gemini

LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins. Use "*" for local dev only.
# In production set this to your actual domain, e.g.: https://yourdomain.com
ALLOWED_ORIGINS=*
